{
  "name": "@forgeui/tokens",
  "version": "1.0.0",
  "license": "MIT",
  "description": "ForgeUI design tokens — CSS variables and JS constants",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "import": "./dist/color.js",
      "require": "./dist/color.cjs"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsx scripts/generate-scales.ts && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "culori": "^4.0.1"
  }
}
